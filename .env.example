# ============================================
#  🔀 RouterAI — Environment Config
#  คัดลอกเป็น .env แล้วใส่ API Key ของคุณ
# ============================================

# --- API Keys (ใส่อย่างน้อย 1 ตัว) ---
GROQ_API_KEY=
MIMO_API_KEY=
GOOGLE_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
CHUTES_API_KEY=
TOGETHER_API_KEY=

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- การตั้งค่า ---
ROUTERAI_HOST=127.0.0.1
ROUTERAI_PORT=8900
LOG_LEVEL=info

# --- Security (ตั้งค่านี้เพื่อป้องกัน /v1/* endpoints) ---
# ROUTERAI_API_KEY=your-secret-key-here

# --- CORS (จำกัด origin ที่เข้าถึง Dashboard API ได้) ---
# ค่าเริ่มต้น: localhost เท่านั้น
# ROUTERAI_CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*
