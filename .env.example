# ============================================
#  🔀 RouterAI — Environment Config
#  คัดลอกเป็น .env แล้วใส่ API Key ของคุณ
# ============================================

# ── API Keys (ใส่อย่างน้อย 1 ตัว) ──────────
GROQ_API_KEY=
MIMO_API_KEY=
GOOGLE_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
CHUTES_API_KEY=
TOGETHER_API_KEY=

# ── Ollama (Local) ─────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── การตั้งค่าพื้นฐาน ───────────────────────
ROUTERAI_HOST=127.0.0.1
ROUTERAI_PORT=8900
LOG_LEVEL=info

# ── 🔒 Security (สำคัญมาก!) ─────────────────
# ⚠️ ตั้งค่านี้เสมอเมื่อ deploy จริง!
# ถ้าไม่ตั้ง ระบบจะสร้างอัตโนมัติและแสดงใน log ครั้งแรก
# สร้าง key ได้ด้วย: python -c "import secrets; print(secrets.token_hex(32))"
ROUTERAI_API_KEY=

# ── Dashboard Login (แนะนำให้ตั้ง!) ─────────
# ตั้งค่านี้เพื่อล็อก Dashboard ด้วยรหัสผ่าน
ROUTERAI_DASHBOARD_PASSWORD=

# ── Caddy / Domain (Production HTTPS) ──────
# สำหรับ production: ตั้ง DOMAIN ของคุณ Caddy จะจัดการ SSL ให้อัตโนมัติ
# DOMAIN=your-domain.com
# ACME_EMAIL=admin@your-domain.com

# ── CORS ────────────────────────────────────
# ⚠️ อย่าใช้ wildcard (*) ใน production!
# ปล่อยว่าง = localhost เท่านั้น (ปลอดภัยที่สุด)
# สำหรับ Docker: ตั้งค่าตาม domain/port ที่ใช้จริง
# ROUTERAI_CORS_ORIGINS=http://localhost:8900,https://your-domain.com

# ── Logging ─────────────────────────────────
# ROUTERAI_LOG_FORMAT=text  (text สำหรับ dev, json สำหรับ production)
