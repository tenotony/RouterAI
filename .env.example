# ============================================
#  🔀 RouterAI v3.5 — Environment Config
#  คัดลอกเป็น .env แล้วใส่ API Key ของคุณ
# ============================================

# ── 🔒 Security ─────────────────────────────
# ⚠️ ไม่ตั้งค่า = ระบบสร้างอัตโนมัติ (แสดงใน log)
# สร้าง key: python3 -c "import secrets; print(secrets.token_hex(32))"
ROUTERAI_API_KEY=

# Dashboard Login (แนะนำให้ตั้ง!)
ROUTERAI_DASHBOARD_PASSWORD=

# ── ⭐ Tier 1: แนะนำ (ฟรี ไม่ต้องบัตรเครดิต) ──
# สมัคร 3 ตัวนี้ก็พอใช้งานได้เลย!
GROQ_API_KEY=             # https://console.groq.com/keys — เร็วสุด
NVIDIA_API_KEY=           # https://build.nvidia.com — 168+ models
CEREBRAS_API_KEY=         # https://cloud.cerebras.ai — 1M tok/day

# ── 🆓 Tier 1: Free ถาวร ──────────────────
MISTRAL_API_KEY=          # https://console.mistral.ai — 1B tok/mo
SAMBANOVA_API_KEY=        # https://cloud.sambanova.ai — 30 RPM
GOOGLE_API_KEY=           # https://aistudio.google.com/apikey
OPENROUTER_API_KEY=       # https://openrouter.ai/settings/keys
CHUTES_API_KEY=           # https://chutes.ai — unlimited
LLM7_API_KEY=             # https://token.llm7.io/
SCALEWAY_API_KEY=         # https://console.scaleway.com
ZAI_API_KEY=              # https://z.ai/manage-apikey/apikey-list
GITHUB_MODELS_TOKEN=      # https://github.com/settings/tokens
COHERE_API_KEY=           # https://dashboard.cohere.com/api-keys
POLLINATIONS_API_KEY=     # https://enter.pollinations.ai/
CLOUDFLARE_API_TOKEN=     # https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=    # สำหรับ Cloudflare Workers AI
SILICONFLOW_API_KEY=      # https://cloud.siliconflow.cn

# ── 💳 Tier 2: Free Credits (มีวันหมดอายุ) ──
TOGETHER_API_KEY=         # https://api.together.xyz/settings/api-keys — $25
REKA_API_KEY=             # https://platform.reka.ai/ — $10/mo auto-refresh
DASHSCOPE_API_KEY=        # https://bailian.console.alibabacloud.com/ — 90 วัน
GLHF_API_KEY=             # https://glhf.chat/
HYPERBOLIC_API_KEY=       # https://app.hyperbolic.ai/signup — $1
HF_TOKEN=                 # https://huggingface.co/settings/tokens — $0.10/mo
FIREWORKS_API_KEY=        # https://fireworks.ai/account/api-keys — $1

# ── 💰 Paid ─────────────────────────────────
DEEPSEEK_API_KEY=         # https://platform.deepseek.com — ถูกมาก
MIMO_API_KEY=             # https://mimo.xiaomi.com

# ── 🏠 Ollama (Local) ──────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama

# ── ⚙️  การตั้งค่า ──────────────────────────
ROUTERAI_PORT=8900
LOG_LEVEL=info
# ROUTERAI_LOG_FORMAT=json     # json สำหรับ production, text สำหรับ dev
# ROUTERAI_CORS_ORIGINS=*      # ⚠️ อย่าใช้ * ใน production!
# ROUTERAI_DEBUG=true          # เปิด auto-reload สำหรับ development
