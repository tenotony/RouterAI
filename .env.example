# ============================================
#  🔀 RouterAI — Environment Config
#  คัดลอกเป็น .env แล้วใส่ API Key ของคุณ
# ============================================

# --- API Keys (ใส่อย่างน้อย 1 ตัว) ---
GROQ_API_KEY=
MIMO_API_KEY=
GOOGLE_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
CHUTES_API_KEY=
TOGETHER_API_KEY=

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- การตั้งค่า ---
ROUTERAI_HOST=127.0.0.1
ROUTERAI_PORT=8900
LOG_LEVEL=info

# --- Security (ตั้งค่านี้เพื่อป้องกัน /v1/* endpoints) ---
# ROUTERAI_API_KEY=your-secret-key-here

# --- Dashboard Login (ตั้งค่านี้เพื่อล็อก Dashboard ด้วยรหัสผ่าน) ---
# ROUTERAI_DASHBOARD_PASSWORD=your-dashboard-password

# --- CORS (จำกัด origin ที่เข้าถึง Dashboard API ได้) ---
# ค่าเริ่มต้น: localhost:8900 เท่านั้น (ปลอดภัยกว่า wildcard)
# สำหรับ Docker หรือ port อื่น ตั้งค่าดังนี้:
# ROUTERAI_CORS_ORIGINS=http://localhost:8900,http://127.0.0.1:8900,http://localhost:3000
# ⚠️ อย่าใช้ wildcard (*) ใน production!

# --- Logging ---
# LOG_LEVEL=info  (debug, info, warning, error)
# ROUTERAI_LOG_FORMAT=text  (text หรือ json — json สำหรับ production monitoring)
