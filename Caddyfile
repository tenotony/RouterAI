# RouterAI — Caddy Reverse Proxy Config (Auto HTTPS)
# ใช้สำหรับ deploy จริง ได้ SSL certificate อัตโนมัติ
#
# ติดตั้ง Caddy: https://caddyserver.com/docs/install
# รัน: caddy run --config Caddyfile
#
# ถ้า RouterAI รันบน port 8900:

# Option 1: Simple reverse proxy (Caddy manages SSL)
your-domain.com {
    reverse_proxy localhost:8900
    encode gzip
}

# Option 2: With basic auth for dashboard
# your-domain.com {
#     basicauth {
#         admin $2a$14$YOUR_BCRYPT_HASH_HERE
#     }
#     reverse_proxy localhost:8900
#     encode gzip
# }

# Option 3: Local HTTPS with self-signed cert (ไม่มี public domain)
# :443 {
#     tls internal
#     reverse_proxy localhost:8900
#     encode gzip
# }
